                "s3:*"
            ],
            "Resource": "*"
        },
        {
            "Sid": "DenyIAMAccess",
            "Effect": "Deny",
            "Action": [
                "iam:*"
            ],
            "Resource": "*"
        },
        {
            "Sid": "DenyAllIAMAccess",
            "Effect": "Deny",
            "Action": [
                "iam:*"
            ],
            "Resource": "*"
        }
    ]
}